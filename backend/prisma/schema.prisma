generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  age             Int?
  education       String?
  skills          String[]
  interests       String[]
  applications    Application[]
  affiliateClicks AffiliateClick[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Course {
  id              String           @id @default(uuid())
  title           String
  description     String?
  provider        String
  type            CourseType
  category        String?
  price           Float?
  currency        String           @default("LKR")
  url             String
  verified        Boolean          @default(false)
  institute       Institute?       @relation(fields: [instituteId], references: [id])
  instituteId     String?
  applications    Application[]
  affiliateClicks AffiliateClick[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum CourseType {
  GOV
  PRIVATE
  GLOBAL
}

model Institute {
  id           String        @id @default(uuid())
  name         String        @unique
  type         String?
  verified     Boolean       @default(false)
  contact      String?
  courses      Course[]
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id          String            @id @default(uuid())
  user        User              @relation(fields: [userId], references: [id])
  userId      String
  course      Course            @relation(fields: [courseId], references: [id])
  courseId    String
  institute   Institute?        @relation(fields: [instituteId], references: [id])
  instituteId String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum ApplicationStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
}

model AffiliateClick {
  id                String   @id @default(uuid())
  user              User?    @relation(fields: [userId], references: [id])
  userId            String?
  course            Course   @relation(fields: [courseId], references: [id])
  courseId          String
  source            String?
  revenueTrackingId String?
  createdAt         DateTime @default(now())
}

model GazetteCourse {
  id             String   @id @default(uuid())
  pdfSource      String
  extractedData  Json
  verifiedStatus Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
